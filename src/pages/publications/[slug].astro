---
import { getCollection, render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

export async function getStaticPaths() {
  const pubs = await getCollection("publications");
  return pubs.map((pub) => ({ params: { slug: pub.id }, props: { pub } }));
}

const { pub } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const { Content } = await render(pub);
---

<Layout
  title={`${pub.data.title} | ${config.site.title}`}
  description={pub.data.excerpt ?? pub.data.title}
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout mt-8 pb-4">
    <a
      href={getRelativeLocaleUrl(locale, "publications")}
      class="text-accent hover:underline text-sm"
    >
      ← 返回论文列表
    </a>

    <h1 class="text-accent mt-3 text-2xl font-bold sm:text-3xl">
      {pub.data.title}
    </h1>
    <p class="text-muted-foreground mt-1">
      {pub.data.year}{pub.data.venue ? ` · ${pub.data.venue}` : ""}
    </p>

    {
      pub.data.url && (
        <p class="mt-3">
          <a
            href={pub.data.url}
            class="text-accent hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            下载论文
          </a>
        </p>
      )
    }

    {
      pub.data.citation && (
        <p class="text-muted-foreground mt-3 text-sm">
          <strong>引用：</strong> {pub.data.citation}
        </p>
      )
    }

    <article
      class="app-prose mt-6 max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>
  </main>
  <Footer />
</Layout>
