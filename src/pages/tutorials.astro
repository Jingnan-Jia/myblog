---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const tutorials = [
  {
    title: "VLA 端到端自动驾驶学习体系",
    description: "涵盖视觉语言动作模型在端到端自动驾驶中的完整学习体系，包括理论基础、模型架构、训练方法和工程实践。",
    path: "/tutorials/vla/",
    tags: ["自动驾驶", "VLA", "深度学习", "端到端"],
  },
];
---

<Layout title={`教程 | ${config.site.title}`}>
  <Header />
  <Breadcrumb />
  <Main pageTitle="教程" pageDesc="学习资源与文档汇总">
    <div class="grid gap-6 md:grid-cols-2">
      {
        tutorials.map((tutorial) => (
          <a
            href={tutorial.path}
            class="border-border bg-card hover:border-accent rounded-lg border p-6 transition-colors"
          >
            <h2 class="text-accent text-xl font-bold">{tutorial.title}</h2>
            <p class="text-muted-foreground mt-2">{tutorial.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {tutorial.tags.map((tag) => (
                <span class="bg-muted rounded-full px-3 py-1 text-xs font-medium">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </Main>
  <Footer />
</Layout>
