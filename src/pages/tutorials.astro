---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const tutorials = [
  {
    title: "VLA 端到端自动驾驶学习体系",
    description: "从 Transformer 基础到 VLA 端到端自动驾驶的完整学习路径（17 章 5 阶段），涵盖 LLM/LLaVA/CLIP 基础、BEV 感知、占据网络、扩散策略、RT-2/OpenVLA 架构与 CARLA 闭环仿真。面向 CNN 感知算法工程师，每章可运行、可实验。",
    path: "/tutorials/vla/",
    tags: ["自动驾驶", "VLA", "Transformer", "BEV", "OpenVLA", "端到端"],
  },
  {
    title: "AI Agent 智能体开发系统教程",
    description: "从零构建 AI Agent 的系统化实践教程（8 个模块），涵盖 ReAct 循环、LangChain/LangGraph、RAG 知识检索、Multi-Agent 协作（CrewAI）、CV Agent 与 Task 自动化，最终构建科研自动化助手。基于 DeepSeek + LangGraph + CrewAI。",
    path: "/tutorials/Agent/",
    tags: ["AI Agent", "LangChain", "LangGraph", "RAG", "CrewAI", "多智能体"],
  },
];
---

<Layout title={`教程 | ${config.site.title}`}>
  <Header />
  <Breadcrumb />
  <Main pageTitle="教程" pageDesc="学习资源与文档汇总">
    <div class="grid gap-6 md:grid-cols-2">
      {
        tutorials.map((tutorial) => (
          <a
            href={tutorial.path}
            class="border-border bg-card hover:border-accent rounded-lg border p-6 transition-colors"
          >
            <h2 class="text-accent text-xl font-bold">{tutorial.title}</h2>
            <p class="text-muted-foreground mt-2">{tutorial.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {tutorial.tags.map((tag) => (
                <span class="bg-muted rounded-full px-3 py-1 text-xs font-medium">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </Main>
  <Footer />
</Layout>
