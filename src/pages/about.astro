---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const homeUrl = getRelativeLocaleUrl(locale, "");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0;url={homeUrl}" />
    <link rel="canonical" href={new URL(homeUrl, config.site.url).href} />
    <title>关于 - 重定向到首页</title>
  </head>
  <body>
    <p>页面已迁移至<a href={homeUrl}>首页</a>。</p>
  </body>
</html>
